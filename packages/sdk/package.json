{
  "name": "@sinnon/sdk",
  "version": "0.8.0",
  "description": "The SINNON platform client — metered EU-hosted models and always-on agents you can dispatch, watch live, and budget from code.",
  "keywords": [
    "sinnon",
    "ai",
    "agents",
    "llm",
    "claude",
    "eu",
    "gdpr",
    "sdk"
  ],
  "license": "MIT",
  "homepage": "https://www.sinnon.net/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitaliKirpuChroma/sinnon-sdk.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/VitaliKirpuChroma/sinnon-sdk/issues"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/write-cjs-marker.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.6.3"
  }
}
